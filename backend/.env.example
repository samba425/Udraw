# DiagramForge backend configuration (all optional; sane defaults apply).
HOST=0.0.0.0
PORT=8787

# Comma-separated allowed CORS origins, or "*" for any. Defaults to the Vite dev server.
CORS_ORIGIN=http://localhost:5173

# Per-IP rate limit.
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=1 minute

LOG_LEVEL=info
APP_VERSION=0.1.0

# Optional AI provider (OpenAI-compatible). Leave blank to use the offline heuristic generator.
# Secrets stay server-side and are never sent to the browser.
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1/chat/completions
