{
  "name": "@samba425/diagramforge-react",
  "private": false,
  "version": "0.1.1",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "Embeddable offline-first diagram editor for React — a draw.io alternative.",
  "author": "samba425 <asiva325@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samba425/Udraw.git",
    "directory": "frontend"
  },
  "keywords": [
    "diagram",
    "flowchart",
    "drawio",
    "react",
    "svg",
    "editor",
    "whiteboard"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/diagramforge.js",
      "require": "./dist/diagramforge.umd.cjs"
    },
    "./styles.css": "./dist/diagramforge.css"
  },
  "main": "./dist/diagramforge.umd.cjs",
  "module": "./dist/diagramforge.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist/diagramforge.js",
    "dist/diagramforge.umd.cjs",
    "dist/diagramforge.css",
    "dist/index.d.ts"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:all": "npm run build && npm run build:lib",
    "preview": "vite preview --host",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "js-yaml": "^5.2.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.469.0",
    "motion": "^11.15.0",
    "nanoid": "^5.0.9",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.1.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.0.0"
  }
}
